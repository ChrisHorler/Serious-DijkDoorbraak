# =========================
# OS / Editor
# =========================
.DS_Store
Thumbs.db
*.swp
*.swo
*.bak
*.tmp
*.orig

.idea/
.vscode/
*.code-workspace

# =========================
# Node / pnpm
# =========================
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
build/
out/
coverage/
*.tsbuildinfo

# =========================
# Next.js
# =========================
.next/
.vercel/
.next-cache/
next-env.d.ts

# =========================
# NestJS / general server
# =========================
# (Nest commonly outputs to dist/, already ignored)

# =========================
# Env files (keep .env.example tracked)
# =========================
.env
.env.*
!.env.example
!.env.local.example

# =========================
# Prisma
# =========================
# Local sqlite DB files (if ever used)
*.db
*.db-journal

# Prisma-generated client is inside node_modules; no ignore needed
# Migrations SHOULD be committed; don't ignore prisma/migrations

# =========================
# Docker
# =========================
# Local overrides / secrets
docker-compose.override.yml
**/docker-compose.override.yml

# Optional: if you store local volumes in-repo (usually you shouldn't)
**/data/
**/.data/
**/volumes/

# =========================
# Logs
# =========================
logs/
*.log

# =========================
# Obsidian vault
# =========================
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-*
.obsidian/cache
.obsidian/cache/*
.obsidian/plugins/*/data.json
.obsidian/plugins/*/main.js.map
.obsidian/plugins/*/*.map

# If you sync vaults, you may also want to ignore:
.trash/
docs/.obsidian/app.json
docs/.obsidian/appearance.json
docs/.obsidian/community-plugins.json
docs/.obsidian/core-plugins.json
docs/.obsidian/workspace.json
docs/.obsidian/plugins/obsidian-kanban/main.js
docs/.obsidian/plugins/obsidian-kanban/manifest.json
