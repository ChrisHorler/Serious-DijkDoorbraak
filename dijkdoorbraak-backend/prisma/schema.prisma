generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Scenario {
  id                String             @id @default(uuid())
  title             String
  description       String?
  phases            Json?
  customOverlays    Json?
  incidentLat       Float?
  incidentLng       Float?
  scenarioTime      String?
  Injects           Inject[]
  sessions          Session[]
  feedbackQuestions FeedbackQuestion[]
  createdAt         DateTime           @default(now())
}

model Inject {
  id          String     @id @default(uuid())
  scenario    Scenario   @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  scenarioId  String
  title       String
  content     String
  triggerTime Int
  targetRole  String?
  variant     String     @default("alert")
  decisions   Decision[]
  createdAt   DateTime   @default(now())
}

model Session {
  id         String        @id @default(uuid())
  scenario   Scenario      @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  scenarioId String
  status     SessionStatus @default(LOBBY)
  joinCode   String        @unique
  players    Player[]
  decisions  Decision[]
  feedbacks  Feedback[]
  logs       SessionLog[]
  createdAt  DateTime      @default(now())
  startedAt  DateTime?
  endedAt    DateTime?
}

model Player {
  id        String     @id @default(uuid())
  session   Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  nickname  String
  role      Role?      @relation(fields: [roleId], references: [id])
  roleId    String?
  socketId  String?
  decisions Decision[]
  joinedAt  DateTime   @default(now())
}

model Decision {
  id            String   @id @default(uuid())
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  playerId      String
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId     String
  inject        Inject?  @relation(fields: [injectId], references: [id])
  injectId      String?
  ability       Ability? @relation(fields: [abilityId], references: [id])
  abilityId     String?
  customAction  String?
  actionLat     Float?
  actionLng     Float?
  actionDetail  String?
  actionUrgency String?
  adminResponse String?
  adminApproved Boolean?
  score         Int?
  timestamp     DateTime @default(now())
}

model Feedback {
  id              String   @id @default(uuid())
  session         Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId       String
  nickname        String
  rating          Int?
  questionRatings Json?
  comment         String?
  submittedAt     DateTime @default(now())
}

model FeedbackQuestion {
  id         String   @id @default(uuid())
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  scenarioId String
  question   String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model Role {
  id          String    @id @default(uuid())
  name        String    @unique
  shortName   String    @unique
  description String
  briefing    String?
  abilities   Ability[]
  players     Player[]
  createdAt   DateTime  @default(now())
}

model Ability {
  id          String     @id @default(uuid())
  role        Role       @relation(fields: [roleId], references: [id])
  roleId      String
  name        String
  description String?
  decisions   Decision[]
  createdAt   DateTime   @default(now())
}

model SessionLog {
  id        String   @id @default(uuid())
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  event     String   // e.g. "scenario_started", "phase_changed", "inject_fired", "player_joined"
  details   Json?
  timestamp DateTime @default(now())

  @@index([sessionId, timestamp])
}

enum SessionStatus {
  LOBBY
  RUNNING
  ENDED
}
